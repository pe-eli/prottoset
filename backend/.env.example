PORT=3001
NODE_ENV=production
CLIENT_URL=http://localhost:5173

# n8n email verification
N8N_VERIFICATION_START_URL=
N8N_VERIFICATION_VALIDATE_URL=
N8N_SHARED_SECRET=
N8N_REQUIRE_SIGNED_RESPONSE=true
N8N_SIGNATURE_MAX_SKEW_MS=300000
N8N_TIMEOUT_MS=10000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prottoset
DATABASE_CA_CERT=

# Auth
AUTH_JWT_SECRET=replace_with_long_random_secret_at_least_64_chars
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_COOKIE_SAMESITE=none
AUTH_REQUIRE_VERIFIED_ACCOUNT_FOR_EXPENSIVE_ACTIONS=true

# Redis / queues / rate limit
REDIS_URL=redis://localhost:6379
RUN_JOB_WORKERS_INLINE=true

# Google OAuth (opcional — deixe vazio para desativar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# APIs externas
SERPER_API_KEY=your_serper_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Prottocode <onboarding@resend.dev>
RESEND_FROM=Prottocode <onboarding@resend.dev>
EVOLUTION_API_URL=https://mellow-motivation-production-ef66.up.railway.app
EVOLUTION_API_KEY=your_evolution_api_key_here
# EVOLUTION_INSTANCE is deprecated — instances are now per-tenant (user_{userId})
# EVOLUTION_INSTANCE=your_instance_name
EVOLUTION_WEBHOOK_URL=https://your-backend-url.com

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MP_PLAN_ID_SOLO=
MP_PLAN_ID_AGENCIA=
MP_PLAN_ID_PRO=
MP_SUCCESS_URL=http://localhost:5173/dashboard?subscribed=true
MP_FAILURE_URL=http://localhost:5173/pricing?error=payment_failed
MP_PENDING_URL=http://localhost:5173/pricing?status=pending
